<Window x:Class="VoiceInput.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="520"
        Height="580"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="#F3F3F3"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- 标签页 -->
        <TabControl x:Name="MainTabControl" Grid.Row="0"
                    SelectedIndex="0">
            
            <!-- 标签页 1: 识别设置 -->
            <TabItem Header="识别设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel>
                        <!-- 识别模式 -->
                        <TextBlock Text="识别模式" FontWeight="SemiBold" Margin="0,0,0,8" />
                        
                        <RadioButton x:Name="ModeLocalRadio" 
                                     Content="本地识别 + LLM 纠错（默认）"
                                     Margin="0,0,0,4"
                                     GroupName="RecognitionMode"
                                     IsChecked="True" />
                        <TextBlock Text="使用 Windows 内置语音识别，转写后可选 LLM 纠错"
                                   Foreground="#666666" Margin="20,0,0,12" />
                        
                        <RadioButton x:Name="ModeAiRadio" 
                                     Content="AI 语音转写（API）"
                                     Margin="0,0,0,4"
                                     GroupName="RecognitionMode" />
                        <TextBlock Text="通过 OpenAI 兼容 ASR API 转写，识别质量更高，需网络"
                                   Foreground="#666666" Margin="20,0,0,16" />
                        
                        <!-- 识别语言 -->
                        <TextBlock Text="识别语言" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ComboBox x:Name="LanguageComboBox" 
                                  SelectedIndex="0"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,16">
                            <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                            <ComboBoxItem Content="English" Tag="en-US" />
                            <ComboBoxItem Content="繁體中文" Tag="zh-TW" />
                            <ComboBoxItem Content="日本語" Tag="ja-JP" />
                            <ComboBoxItem Content="한국어" Tag="ko-KR" />
                        </ComboBox>
                        
                        <!-- 触发按键 -->
                        <TextBlock Text="触发按键" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ComboBox x:Name="TriggerKeyComboBox"
                                  SelectedIndex="0"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,8">
                            <ComboBoxItem Content="右 Alt 键（默认）" Tag="RightAlt" />
                            <ComboBoxItem Content="左 Alt 键" Tag="LeftAlt" />
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 标签页 2: API 配置 -->
            <TabItem Header="API 配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel>
                        <!-- API Base URL -->
                        <TextBlock Text="API Base URL" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBox x:Name="ApiBaseUrlTextBox"
                                 HorizontalAlignment="Stretch"
                                 Margin="0,0,0,4" />
                        <TextBlock Text="如：https://api.openai.com"
                                   Foreground="#666666" Margin="0,0,0,16" />
                        
                        <!-- API Key -->
                        <TextBlock Text="API Key" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <PasswordBox x:Name="ApiKeyPasswordBox"
                                     HorizontalAlignment="Stretch"
                                     Margin="0,0,0,16" />
                        
                        <!-- 模型配置 -->
                        <Border Background="#E8E8E8" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="模型配置" FontWeight="SemiBold" Margin="0,0,0,12" />
                                
                                <TextBlock Text="转写模型（AI 转写模式使用）" Margin="0,0,0,4" />
                                <TextBox x:Name="AsrModelTextBox"
                                         HorizontalAlignment="Stretch"
                                         Margin="0,0,0,4" />
                                <TextBlock Text="调用 /v1/audio/transcriptions 端点"
                                           Foreground="#666666" FontSize="11"
                                           Margin="0,0,0,12" />
                                
                                <TextBlock Text="纠错模型（LLM 纠错使用）" Margin="0,0,0,4" />
                                <TextBox x:Name="LlmModelTextBox"
                                         HorizontalAlignment="Stretch"
                                         Margin="0,0,0,4" />
                                <TextBlock Text="调用 /v1/chat/completions 端点"
                                           Foreground="#666666" FontSize="11"
                                           Margin="0,0,0,12" />
                                
                                <Button x:Name="TestConnectionButton"
                                        Content="测试连接"
                                        HorizontalAlignment="Left"
                                        Padding="16,8"
                                        Click="TestConnectionButton_Click" />
                                
                                <TextBlock x:Name="TestResultText"
                                           Text=""
                                           Margin="0,8,0,0"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>
                        
                        <!-- LLM 纠错 -->
                        <Border Background="#E8E8E8" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="LLM 纠错" FontWeight="SemiBold" Margin="0,0,0,8" />
                                
                                <CheckBox x:Name="EnableLlmCorrectionCheckBox"
                                          Content="启用 LLM 纠错"
                                          IsChecked="True" />
                                <TextBlock Text="转写完成后，将文字发送给纠错模型修正明显识别错误"
                                           Foreground="#666666" Margin="20,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 标签页 3: 界面与显示 -->
            <TabItem Header="界面与显示">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel>
                        <!-- 应用界面语言 -->
                        <TextBlock Text="应用界面语言" FontWeight="SemiBold" Margin="0,0,0,8" />
                        
                        <RadioButton x:Name="UiLangZhRadio"
                                     Content="简体中文（默认）"
                                     Margin="0,0,0,4"
                                     GroupName="UiLanguage"
                                     IsChecked="True" />
                        <RadioButton x:Name="UiLangEnRadio"
                                     Content="English"
                                     Margin="0,0,0,16"
                                     GroupName="UiLanguage" />
                        
                        <!-- HUD 位置偏移 -->
                        <TextBlock Text="HUD 位置偏移（距屏幕底部距离）" 
                                   FontWeight="SemiBold" Margin="0,0,0,8" />
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <Slider x:Name="HudOffsetSlider"
                                    Grid.Column="0"
                                    Minimum="16" Maximum="120" Value="32"
                                    TickFrequency="8" IsSnapToTickEnabled="True"
                                    ValueChanged="HudOffsetSlider_ValueChanged" />
                            
                            <TextBlock x:Name="HudOffsetValueText"
                                       Grid.Column="1"
                                       Text="32 DIU"
                                       Margin="12,0,0,0"
                                       MinWidth="50"
                                       TextAlignment="Right" />
                        </Grid>
                        <TextBlock Text="默认 32 DIU，范围 16-120 DIU"
                                   Foreground="#666666" Margin="0,8,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        
        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="SaveButton"
                    Content="保存"
                    Padding="24,8"
                    Margin="0,0,8,0"
                    Click="SaveButton_Click" />
            
            <Button x:Name="CancelButton"
                    Content="取消"
                    Padding="24,8"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
