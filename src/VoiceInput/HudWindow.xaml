<Window x:Class="VoiceInput.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceInput HUD"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        Width="200"
        Height="56"
        MinWidth="160"
        MaxWidth="560"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    
    <Window.Resources>
        <!-- 背景画刷 -->
        <SolidColorBrush x:Key="HudBackgroundBrush" Color="#CC1C1C1E" />
        
        <!-- 前景画刷 -->
        <SolidColorBrush x:Key="HudForegroundBrush" Color="#FFFFFF" />
        
        <!-- 动画资源 -->
        <Storyboard x:Key="ShowStoryboard">
            <!-- 入场动画：透明度 -->
            <DoubleAnimation Storyboard.TargetName="HudBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.3" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <!-- 入场动画：缩放 -->
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.85" To="1.0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.3" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.85" To="1.0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.3" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <Storyboard x:Key="HideStoryboard">
            <!-- 退场动画：透明度 -->
            <DoubleAnimation Storyboard.TargetName="HudBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <!-- 退场动画：缩放 -->
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="0.9" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="0.9" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
    <Border x:Name="HudBorder"
            Background="{StaticResource HudBackgroundBrush}"
            CornerRadius="28"
            Padding="16,0"
            ClipToBounds="True">
        
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleTransform" CenterX="0.5" CenterY="0.5" />
            </TransformGroup>
        </Border.RenderTransform>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- 波形区域 -->
                <ColumnDefinition Width="Auto" />
                <!-- 间隔 -->
                <ColumnDefinition Width="12" />
                <!-- 文本区域 -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- 波形动画区域 -->
            <Canvas Grid.Column="0"
                    Width="44" Height="32"
                    VerticalAlignment="Center">
                
                <!-- 5 根波形条 -->
                <Rectangle x:Name="Bar1" Width="3" Height="4"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1.5" RadiusY="1.5"
                           Canvas.Left="0" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar2" Width="3" Height="4"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1.5" RadiusY="1.5"
                           Canvas.Left="9" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar3" Width="3" Height="4"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1.5" RadiusY="1.5"
                           Canvas.Left="18" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar4" Width="3" Height="4"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1.5" RadiusY="1.5"
                           Canvas.Left="27" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar5" Width="3" Height="4"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1.5" RadiusY="1.5"
                           Canvas.Left="36" Canvas.Bottom="0" />
            </Canvas>
            
            <!-- 转录文本区域 -->
            <TextBlock x:Name="TextBlock"
                       Grid.Column="2"
                       Text=""
                       FontFamily="Segoe UI Variable, Segoe UI"
                       FontSize="14"
                       FontWeight="Regular"
                       Foreground="{StaticResource HudForegroundBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextOptions.TextFormattingMode="Display"
                       MaxWidth="480" />
        </Grid>
    </Border>
</Window>
