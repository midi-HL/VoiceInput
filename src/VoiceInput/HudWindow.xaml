<Window x:Class="VoiceInput.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceInput HUD"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        Width="200"
        Height="40"
        MinWidth="140"
        MaxWidth="500"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    
    <Window.Resources>
        <!-- 背景画刷 - Windows 11 深色风格 -->
        <SolidColorBrush x:Key="HudBackgroundBrush" Color="#E0202024" />
        
        <!-- 前景画刷 -->
        <SolidColorBrush x:Key="HudForegroundBrush" Color="#FFFFFF" />
        
        <!-- 次要前景画刷 -->
        <SolidColorBrush x:Key="HudSecondaryForegroundBrush" Color="#A0FFFFFF" />
        
        <!-- 动画资源 - Windows 11 风格 -->
        <Storyboard x:Key="ShowStoryboard">
            <!-- 入场动画：透明度 -->
            <DoubleAnimation Storyboard.TargetName="HudBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <!-- 入场动画：缩放 -->
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.95" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.95" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <Storyboard x:Key="HideStoryboard">
            <!-- 退场动画：透明度 -->
            <DoubleAnimation Storyboard.TargetName="HudBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <!-- 退场动画：缩放 -->
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="0.95" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="0.95" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
    <Border x:Name="HudBorder"
            Background="{StaticResource HudBackgroundBrush}"
            CornerRadius="8"
            Padding="12,0"
            ClipToBounds="True">
        
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ScaleTransform" CenterX="0.5" CenterY="0.5" />
            </TransformGroup>
        </Border.RenderTransform>
        
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.3" ShadowDepth="0" Color="#000000" />
        </Border.Effect>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- 波形区域 -->
                <ColumnDefinition Width="Auto" />
                <!-- 间隔 -->
                <ColumnDefinition Width="10" />
                <!-- 文本区域 -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- 波形动画区域 - 更精致的频谱 -->
            <Canvas Grid.Column="0"
                    Width="32" Height="24"
                    VerticalAlignment="Center">
                
                <!-- 7 根波形条 - 更细更精致 -->
                <Rectangle x:Name="Bar1" Width="2" Height="3"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1" RadiusY="1"
                           Canvas.Left="0" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar2" Width="2" Height="3"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1" RadiusY="1"
                           Canvas.Left="5" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar3" Width="2" Height="3"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1" RadiusY="1"
                           Canvas.Left="10" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar4" Width="2" Height="3"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1" RadiusY="1"
                           Canvas.Left="15" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar5" Width="2" Height="3"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1" RadiusY="1"
                           Canvas.Left="20" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar6" Width="2" Height="3"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1" RadiusY="1"
                           Canvas.Left="25" Canvas.Bottom="0" />
                
                <Rectangle x:Name="Bar7" Width="2" Height="3"
                           Fill="{StaticResource HudForegroundBrush}"
                           RadiusX="1" RadiusY="1"
                           Canvas.Left="30" Canvas.Bottom="0" />
            </Canvas>
            
            <!-- 转录文本区域 -->
            <TextBlock x:Name="TextBlock"
                       Grid.Column="2"
                       Text=""
                       FontFamily="Segoe UI Variable, Segoe UI"
                       FontSize="12"
                       FontWeight="Regular"
                       Foreground="{StaticResource HudForegroundBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextOptions.TextFormattingMode="Display"
                       MaxWidth="440" />
        </Grid>
    </Border>
</Window>
