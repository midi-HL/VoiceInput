<Page
    x:Class="VoiceInput.Pages.InterfaceSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="0,16,0,0">
        <StackPanel Spacing="24" MaxWidth="600">
            <!-- App Language -->
            <StackPanel Spacing="8">
                <TextBlock Text="应用界面语言" FontSize="15" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <RadioButton x:Name="ChineseRadio" Content="简体中文（默认）"
                             Checked="AppLanguage_Changed" Margin="0,4,0,0" />
                <RadioButton x:Name="EnglishRadio" Content="English"
                             Checked="AppLanguage_Changed" />
            </StackPanel>

            <!-- HUD Offset -->
            <StackPanel Spacing="8">
                <TextBlock Text="HUD 位置偏移（距屏幕底部距离）" FontSize="15" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <Slider x:Name="HudOffsetSlider" Minimum="16" Maximum="120" Value="32"
                        StepFrequency="1" Width="300"
                        ValueChanged="HudOffset_Changed" />
            </StackPanel>

            <!-- Close Behavior -->
            <StackPanel Spacing="8">
                <TextBlock Text="关闭窗口行为" FontSize="15" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <RadioButton x:Name="MinimizeRadio" Content="最小化到托盘（默认）"
                             Checked="CloseBehavior_Changed" Margin="0,4,0,0" />
                <RadioButton x:Name="CloseRadio" Content="关闭应用"
                             Checked="CloseBehavior_Changed" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
