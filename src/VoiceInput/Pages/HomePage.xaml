<Page
    x:Class="VoiceInput.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceInput.Pages"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Padding="32,24,32,32" Spacing="24">
            <!-- Page Title -->
            <StackPanel Spacing="4">
                <TextBlock
                    Text="主页"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock
                    Text="按住 右Alt 键 开始语音输入"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Feature Cards -->
            <ItemsRepeater x:Name="FeatureCards">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        ItemsStretch="Fill"
                        MinColumnSpacing="12"
                        MinRowSpacing="12"
                        MinItemWidth="240"
                        MinItemHeight="100" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:FeatureCard">
                        <Button
                            Click="Card_Click"
                            Tag="{x:Bind Tag}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon
                                    Glyph="{x:Bind IconGlyph}"
                                    FontSize="24"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock
                                        Text="{x:Bind Title}"
                                        FontSize="14"
                                        FontWeight="Medium"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock
                                        Text="{x:Bind Description}"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- Status Area -->
            <StackPanel
                x:Name="StatusArea"
                Spacing="4"
                Padding="0,8,0,0">
                <TextBlock
                    x:Name="StatusText"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
