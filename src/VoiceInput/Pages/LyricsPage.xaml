<Page
    x:Class="VoiceInput.Pages.LyricsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VoiceInput.Pages"
    Background="Transparent">

    <Grid Padding="32,24,32,32" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Title -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock
                Text="歌词识别"
                FontSize="24"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <TextBlock
                Text="上传音频文件，自动识别并提取歌词"
                FontSize="13"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel - File Upload -->
            <Border
                Grid.Column="0"
                CornerRadius="8"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                AllowDrop="True"
                DragOver="UploadArea_DragOver"
                Drop="UploadArea_Drop"
                Tapped="UploadArea_Tapped">

                <StackPanel
                    x:Name="UploadPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8">

                    <FontIcon
                        x:Name="UploadIcon"
                        Glyph="&#xE74A;"
                        FontSize="32"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center" />

                    <TextBlock
                        x:Name="UploadText"
                        Text="点击上传文件或拖入文件"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center" />

                    <TextBlock
                        Text="支持格式: MP3, WAV, FLAC, OGG, M4A, AAC"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- File Info (hidden by default) -->
            <StackPanel
                x:Name="FileInfoPanel"
                Grid.Column="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="8"
                Visibility="Collapsed">

                <FontIcon
                    Glyph="&#xE7C3;"
                    FontSize="32"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    x:Name="FileNameText"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    HorizontalAlignment="Center"
                    TextAlignment="Center" />

                <TextBlock
                    x:Name="FileDetailsText"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />

                <Button
                    Content="重新选择"
                    Click="Reselect_Click"
                    HorizontalAlignment="Center"
                    Style="{ThemeResource SubtleButtonStyle}" />

                <Button
                    x:Name="StartRecognizeButton"
                    Content="开始识别"
                    Click="StartRecognize_Click"
                    HorizontalAlignment="Center"
                    Style="{ThemeResource AccentButtonStyle}"
                    Margin="0,8,0,0" />
            </StackPanel>

            <!-- Right Panel - Lyrics Output -->
            <Border
                Grid.Column="1"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="16">

                <Grid>
                    <!-- Default State -->
                    <TextBlock
                        x:Name="PlaceholderText"
                        Text="识别出的歌词将显示在这里"
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />

                    <!-- Loading State -->
                    <StackPanel
                        x:Name="LoadingPanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                        <ProgressRing IsActive="True" />
                        <TextBlock
                            x:Name="LoadingText"
                            Text="正在识别歌词..."
                            FontSize="14"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Result State -->
                    <Grid Visibility="Collapsed" x:Name="ResultGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0">
                            <TextBlock
                                x:Name="LyricsText"
                                FontSize="14"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                TextWrapping="Wrap"
                                IsTextSelectionEnabled="True"
                                LineHeight="24" />
                        </ScrollViewer>

                        <CommandBar
                            Grid.Row="1"
                            DefaultLabelPosition="Right"
                            HorizontalAlignment="Stretch"
                            Background="Transparent">
                            <AppBarButton
                                Label="复制全部"
                                Icon="Copy"
                                Click="CopyAll_Click" />
                            <AppBarButton
                                Label="导出 .lrc"
                                Icon="Save"
                                Click="ExportLrc_Click" />
                            <AppBarButton
                                Label="清空"
                                Icon="Clear"
                                Click="Clear_Click" />
                        </CommandBar>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
